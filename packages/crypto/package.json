{
  "name": "@safu/crypto",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build:wasm": "wasm-pack build ../../crates/safu-crypto --release --target web --out-dir ../../packages/crypto/wasm --out-name safu_crypto",
    "build": "pnpm build:wasm && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
