{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Safu",
  "version": "0.0.0",
  "identifier": "io.sharu.safu",
  "build": {
    "beforeDevCommand": "pnpm --filter @safu/web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @safu/web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Safu",
        "width": 960,
        "height": 720,
        "resizable": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "Safu — backing up"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
